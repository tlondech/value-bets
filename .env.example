# The Odds API — https://the-odds-api.com (free: 500 req/month)
THE_ODDS_API_KEY=your_key_here

# NewsAPI — optional; enables team news/injury context for EV ≥ 20% signals within 24h of kickoff
# Free tier: 100 req/day — https://newsapi.org/register
NEWS_API_KEY=

# Optional overrides (defaults shown)
# Comma-separated league keys to run. Leave blank to run all leagues.
# Valid keys: ligue1, epl, laliga, bundesliga, seriea, ucl, worldcup
# ENABLED_LEAGUES=

# EV_THRESHOLD=0.05
# ROLLING_WINDOW=5
# POISSON_MAX_GOALS=8
# ODDS_TOTALS_BOOKMAKERS=pinnacle   # fallback bookmaker(s) for O/U 2.5 when Winamax has no line
